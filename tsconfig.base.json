{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@rezovo/core-types/*": ["packages/core-types/src/*"],
      "@rezovo/event-bus/*": ["packages/event-bus/src/*"],
      "@rezovo/logging/*": ["packages/logging/src/*"],
      "@rezovo/utils/*": ["packages/utils/src/*"],
      "@rezovo/voice-elevenlabs/*": ["packages/voice-elevenlabs/src/*"],
      "@rezovo/vector-store": ["packages/vector-store/src"],
      "@rezovo/vector-store/*": ["packages/vector-store/src/*"]
    }
  }
}

