{
  "name": "voip-receptionist",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "format": "pnpm -r --if-present format",
    "kill-ports": "bash scripts/kill-dev-ports.sh",
    "dev:api": "pnpm --filter @rezovo/platform-api dev",
    "dev:web": "pnpm --filter frontend dev"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1020.0",
    "@types/uuid": "^11.0.0",
    "twilio": "^5.13.1",
    "uuid": "^13.0.0"
  }
}
