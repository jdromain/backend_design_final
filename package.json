{
  "name": "voip-receptionist",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "format": "pnpm -r --if-present format",
    "kill-ports": "bash scripts/kill-dev-ports.sh",
    "dev:api": "pnpm --filter @rezovo/platform-api dev",
    "dev:web": "pnpm --filter frontend dev",
    "dev:jobs": "pnpm --filter @rezovo/jobs start",
    "dev:realtime": "pnpm --filter @rezovo/realtime-core dev",
    "stack:up": "bash scripts/stack-up.sh",
    "stack:down": "bash scripts/stack-down.sh",
    "stack:logs": "bash scripts/stack-logs.sh",
    "stack:fresh": "bash scripts/fresh-demo-postgres.sh",
    "stack:restart": "bash scripts/restart-demo-stack.sh"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1020.0",
    "@types/uuid": "^11.0.0",
    "twilio": "^5.13.1",
    "uuid": "^13.0.0"
  }
}
