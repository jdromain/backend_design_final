# Example Terraform variables file
# Copy this to terraform.tfvars and customize for your deployment

aws_region = "us-east-1"
environment = "prod"
project_name = "rezovo"

# VPC Configuration
vpc_cidr = "10.0.0.0/16"

# Feature Flags
enable_kafka = true   # Set to false to save ~$450/month (uses in-memory event bus)
enable_redis = true   # Set to false to save ~$300/month (no caching)

# Auto-scaling Configuration
realtime_core_min_tasks = 2
realtime_core_max_tasks = 50

platform_api_min_tasks = 2
platform_api_max_tasks = 10

# Domain Configuration (optional)
domain_name = "rezovo.ai"
acm_certificate_arn = ""  # ARN of ACM certificate (create in AWS Console first)




