# ─── platform-api environment variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored. Never commit real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# Database (Postgres + pgvector)
# Local dev: postgresql://rezovo:rezovo_local@localhost:5432/rezovo
# Aurora:    postgresql://user:pass@your-cluster.rds.amazonaws.com:5432/rezovo
DATABASE_URL=postgresql://rezovo:rezovo_local@localhost:5432/rezovo
DB_POOL_MAX=5
DB_SSL=false

# Clerk Authentication
CLERK_AUTH_ENABLED=true
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
CLERK_WEBHOOK_SECRET=whsec_...

# Redis (set REDIS_ENABLED=true to activate)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Kafka (set KAFKA_ENABLED=true to activate)
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092

# API Keys
OPENAI_API_KEY=sk-...
STT_API_KEY=your-deepgram-api-key
ELEVEN_API_KEY=your-elevenlabs-api-key
ELEVEN_VOICE_ID=your-elevenlabs-voice-id

# Internal service auth bridge (realtime-core -> platform-api)
INTERNAL_SERVICE_TOKEN=change-me-shared-internal-token

# Toolbus — see docs/setup.md ("Tool connectors")
# When true, external tool connectors use mocked responses. When false, empty organization
# credentials still force the mock path for most connectors (with a server warning).
MOCK_CONNECTORS=false

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Internal service URLs
# RTP_BRIDGE_PUBLIC_URL is the public-facing URL of rtp-bridge for Twilio Media Streams
RTP_BRIDGE_PUBLIC_URL=wss://your-tunnel.example.com
REALTIME_CORE_URL=http://localhost:3002
PLATFORM_API_URL=http://localhost:3001
