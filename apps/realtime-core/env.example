# ─── realtime-core environment variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored. Never commit real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# LLM (OpenAI)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-5-nano
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=800
CONVERSATION_ENGINE=legacy
MODEL_GUARDRAILS_MAX_HISTORY_ITEMS=240
MODEL_GUARDRAILS_MAX_TOTAL_TEXT_CHARS=60000
MODEL_GUARDRAILS_MAX_ITEM_TEXT_CHARS=4000
AGENT_APPROVAL_TTL_MS=120000
AGENT_MAX_BASE_PROMPT_CHARS=260
AGENT_MAX_OPENING_HOURS_CHARS=180
AGENT_MAX_KB_PROMPT_PASSAGES=2
AGENT_MAX_KB_PROMPT_CHARS=220
AGENT_MAX_SLOT_PROMPT_FIELDS=6
AGENT_MAX_SLOT_PROMPT_CHARS=42

# STT — Speech-to-Text (Deepgram or mock for smoke without keys)
STT_PROVIDER=mock
STT_API_KEY=
STT_MODEL=nova-2-phonecall
LEGACY_FINAL_DEBOUNCE_MS=400
LEGACY_STT_ENDPOINTING_MS=600
LEGACY_STT_UTTERANCE_END_MS=1500

# TTS — Text-to-Speech (ElevenLabs)
ELEVEN_API_KEY=your-elevenlabs-api-key
ELEVEN_VOICE_ID=your-elevenlabs-voice-id
ELEVEN_MODEL_ID=eleven_flash_v2_5
LEGACY_TTS_MIN_CHUNK_CHARS=28
LEGACY_TTS_MAX_CHUNK_CHARS=180
LEGACY_TTS_MAX_CHUNK_WAIT_MS=300
LEGACY_OUTPUT_MODERATION_TIMEOUT_MS=250
LEGACY_KB_CACHE_TTL_MS=60000
LEGACY_KB_FETCH_TIMEOUT_MS=450
LEGACY_MAX_KB_PASSAGES=4
LEGACY_MAX_KB_PASSAGE_CHARS=360
LEGACY_MAX_RECENT_USER_TURNS_FOR_RUN=3
LEGACY_MAX_RUN_WINDOW_ITEMS=36
LEGACY_LOG_TEXT_PREVIEW_CHARS=220
LEGACY_INPUT_GUARDRAIL_LONG_INPUT_CHARS=260
LEGACY_SILENCE_PROMPT_MS=8000
LEGACY_MAX_SILENCE_PROMPTS=2
LEGACY_SILENCE_CHECK_INTERVAL_MS=2000
LEGACY_CALL_END_POLL_INTERVAL_MS=200
LEGACY_DEFAULT_MAX_CALL_DURATION_SEC=1800
GUARDRAILS_MAX_WARNINGS_BEFORE_TRANSFER=2
GUARDRAILS_MODERATION_MODEL=omni-moderation-latest
GUARDRAILS_MODERATION_COOLDOWN_MS=300000
REALTIME_KB_FETCH_TIMEOUT_MS=350
REALTIME_PERSIST_THROTTLE_MS=250
REALTIME_EMPTY_RESPONSE_GRACE_MS=1200
REALTIME_TTS_MIN_CHUNK_CHARS=28
REALTIME_TTS_MAX_CHUNK_CHARS=180
REALTIME_TTS_MAX_CHUNK_WAIT_MS=300
REALTIME_OUTPUT_MODERATION_TIMEOUT_MS=250

# Database (Postgres + pgvector) — same as platform-api
DATABASE_URL=postgresql://rezovo:rezovo_local@localhost:5432/rezovo

# Redis + shared event bus (match platform-api / jobs for ConfigChanged across processes)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
EVENT_BUS_IMPL=memory

# Kafka (set KAFKA_ENABLED=true to activate)
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=realtime-core

# RTP Bridge (WebSocket media bridge)
RTP_BRIDGE_URL=ws://localhost:8081
RTP_BRIDGE_CONNECT_TIMEOUT_MS=5000

# Internal service URLs
PLATFORM_API_URL=http://localhost:3001
# Shared with platform-api INTERNAL_SERVICE_TOKEN
INTERNAL_SERVICE_TOKEN=change-me-shared-internal-token
# First config snapshot organization (must match DB seeds, e.g. org_localdemo)
REALTIME_BOOTSTRAP_ORG_ID=org_localdemo

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Runtime
CONCURRENCY_LIMIT=20
METRICS_PORT=9100
WEBHOOK_LISTEN_PORT=3002
LOG_LEVEL=info
NODE_OPTIONS=--max-old-space-size=512
UV_THREADPOOL_SIZE=4
