# Copy to .env.local

NEXT_PUBLIC_API_URL=http://localhost:3001
# Dev JWT fallback only (must match DB seeds when not using Clerk for API tenant)
NEXT_PUBLIC_DEFAULT_TENANT_ID=test-tenant
# Align with platform-api: dev JWT → CLERK_AUTH_ENABLED=false + NEXT_PUBLIC_CLERK_ENABLED=false; Clerk → both true (see docs/AUTH_CLERK.md)

# --- Clerk mode: explicit true required (publishable key alone does not enable Clerk) ---
NEXT_PUBLIC_CLERK_ENABLED=true
# Or use CLERK_ENABLED=true (injected into client via next.config)

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=platform-api

# --- Dev JWT mode: turn Clerk off ---
# NEXT_PUBLIC_CLERK_ENABLED=false
# CLERK_ENABLED=false

# Optional: allow /dev-login in production-like builds
# NEXT_PUBLIC_ENABLE_DEV_LOGIN=false
