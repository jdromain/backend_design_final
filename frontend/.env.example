# Copy to .env.local for local demo
NEXT_PUBLIC_API_URL=http://localhost:3001
# Must match seeded tenants (supabase) and platform-api CLERK_DEFAULT_TENANT_ID when using query fallback
NEXT_PUBLIC_DEFAULT_TENANT_ID=test-tenant

# Clerk — publishable key required for sign-in and ClerkTokenBridge (API Bearer)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# JWT template name in Clerk Dashboard (Session token template)
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=platform-api
# Optional: add custom claim tenant_id in that template so it matches users.tenant_id in Postgres
# Clerk: set to false to use JWT dev-login while keeping keys in env
CLERK_ENABLED=true
