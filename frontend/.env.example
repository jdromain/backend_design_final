# Copy to .env.local

NEXT_PUBLIC_API_URL=http://localhost:3001
# Organization fallback for local reads when API does not provide auth claims
NEXT_PUBLIC_DEFAULT_ORG_ID=org_localdemo
# Clerk-first auth

# --- Clerk mode: explicit true required (publishable key alone does not enable Clerk) ---
NEXT_PUBLIC_CLERK_ENABLED=true
# Or use CLERK_ENABLED=true (injected into client via next.config)

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=platform-api
